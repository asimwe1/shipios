    "build": "npm --workspace @shipios/web run build",
    "lint": "npm --workspace @shipios/web run lint",
    "test:rust": "cargo test --workspace"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asimwe1/shipios.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/asimwe1/shipios/issues"
  },
  "homepage": "https://github.com/asimwe1/shipios#readme",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
